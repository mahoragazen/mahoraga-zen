# Mahoraga ZEN — Environment Variables
# Copy this file to .env and fill in the values
# In Netlify: Site settings → Environment variables

# ── Resend (email service) ─────────────────────────────────────
# สร้าง account ที่ https://resend.com
# แล้วไปที่ API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sender email ──────────────────────────────────────────────
# ต้อง verify domain ที่ resend.com ก่อน
# ระหว่างทดสอบ: ใช้ onboarding@resend.dev (ส่งได้เฉพาะอีเมลของตัวเอง)
# Production: newsletter@mahoragazen.co (หลัง verify domain)
FROM_EMAIL=Mahoraga ZEN <newsletter@mahoragazen.co>

# ── Omise (payment gateway) ────────────────────────────────────
# สมัคร account ที่ https://dashboard.omise.co/signup
# Keys อยู่ที่: Settings → Keys
#
# Public key (ใส่ใน index.html <script> ด้วย window.__OMISE_PUBLIC_KEY__)
OMISE_PUBLIC_KEY=pkey_test_xxxxxxxxxxxxxxxxxx
#
# Secret key (ใช้เฉพาะ backend — ห้าม expose ใน frontend!)
OMISE_SECRET_KEY=skey_test_xxxxxxxxxxxxxxxxxx
